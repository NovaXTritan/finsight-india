# FinSight India — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/finsight

# ============================================================
# ANGEL ONE SMARTAPI (Required for market data)
# Get credentials at: https://smartapi.angelone.in/
# ============================================================
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
ANGEL_PIN=your_trading_pin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Scheduler secret for internal endpoints
SCHEDULER_SECRET=generate_with_openssl_rand_hex_16

# ============================================================
# REDDIT API (Optional — for social sentiment)
# Register at: https://www.reddit.com/prefs/apps
# ============================================================
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=finsight-india/1.0

# ============================================================
# LLM PROVIDER (Optional — for signal contextualizer)
# Default: LM Studio local server
# For cloud: use Anthropic, OpenAI, or similar API
# ============================================================
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
# LLM_API_KEY=your_api_key_here  # Uncomment for cloud LLM

# ============================================================
# APPLICATION
# ============================================================
APP_ENV=development
API_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# ============================================================
# DETECTION PARAMETERS
# ============================================================
ZSCORE_THRESHOLD=2.0
ROLLING_WINDOW=20
SEVERITY_HIGH=3.0
SEVERITY_CRITICAL=4.0
